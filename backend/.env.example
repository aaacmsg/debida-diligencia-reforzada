# Application
APP_NAME="Diligencia Reforzada EDD"
APP_VERSION="1.0.0"
DEBUG=true

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diligencia_db

# Security - IMPORTANT: Change this in production!
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=["pdf","png","jpg","jpeg"]

# PEP Data Sources (datosabiertos.gob.pa)
DATOS_ABIERTOS_BASE_URL=https://www.datosabiertos.gob.pa/api/3
DATOS_ABIERTOS_DOWNLOAD_BASE=https://monitoreo.antai.gob.pa/api/designations/download

# Scoring Weights
SCORE_PAIS_PESO=0.25
SCORE_CARGO_PESO=0.30
SCORE_SECTOR_PESO=0.15
SCORE_VINCULOS_PESO=0.20
SCORE_ORIGEN_FONDOS_PESO=0.10

# Thresholds
FUZZY_MATCH_THRESHOLD=85
BENEFICIARIO_FINAL_PORCENTAJE_MIN=10.0
RIESGO_BAJO_MAX=35
RIESGO_MEDIO_MAX=65

# Retention
RETENTION_YEARS=5

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0
